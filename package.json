{
  "name": "@ragnarokansh/cimp-connect",
  "version": "0.4.2",
  "description": "Connect any backend to a CIMP support portal — mint hand-off tokens and redirect users to the reporter form. Adapters for Express, NestJS, Next.js, React and Web Components (Angular/Vue/Svelte); Spring Boot lives in ./java.",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RagnarokAnsh/cimp-connect.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "nestjs": ["dist/nestjs/index.d.ts"],
      "express": ["dist/express/index.d.ts"],
      "next": ["dist/next/index.d.ts"],
      "react": ["dist/react/index.d.ts"],
      "element": ["dist/element/index.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "default": "./dist/nestjs/index.js"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "default": "./dist/express/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./element": {
      "types": "./dist/element/index.d.ts",
      "default": "./dist/element/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "cimp-connect": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9",
    "@nestjs/core": ">=9",
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
